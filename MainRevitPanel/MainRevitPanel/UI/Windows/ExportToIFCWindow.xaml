<Window x:Class="MainRevitPanel.UI.Windows.ExportToIFCWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MainRevitPanel.UI.Windows"
             mc:Ignorable="d" 
             Title="Экспорт в IFC" Height="300" Width="600" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="25"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="120"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- Имя файла -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- остальные строки -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Text="Имя файла"/>
            <TextBlock Grid.Row="1" Grid.Column="0" 
                Text="{Binding PathSave}" 
                VerticalAlignment="Center"
                Margin="0,0,10,0"/>
            <Button Grid.Row="1" 
                Grid.Column="1" 
                Content="Обзор..." 
                Width="80"
                Command="{Binding PathCommand}"/>
        </Grid>


        <!-- Набор параметров -->
        <TextBlock Grid.Row="1" Text="Текущий выбранный набор параметров:" Margin="0,5"/>
        <ComboBox
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            ItemsSource="{Binding Settings}"
            SelectedItem="{Binding SelectedSettings}"
            Text="&lt;Параметры в сеансе&gt;"
            Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Создать модель GIP VISON" Margin="0,15,0,5"/>
        <ComboBox 
            Grid.Row="4"
            ItemsSource="{Binding CreateModel}"
            DisplayMemberPath="Key" 
            SelectedValuePath="Value"
            SelectedValue ="{Binding SelectedCreateModel}"
            Margin="0,0,0,15"/>

        <!-- Нижняя панель -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button 
                Grid.Column="1" 
                Content="Экспорт" 
                Width="80" 
                Margin="0,0,10,0" 
                Background="#FFE0E0E0" 
                BorderBrush="#FF707070"
                Command="{Binding ApplyCommand}"/>
            <Button 
                Grid.Column="2"
                Content="Отмена"
                Width="80"
                Background="#FFE0E0E0"
                BorderBrush="#FF707070"
                Command="{Binding ClosedCommand}"/>
        </Grid>
    </Grid>
</Window>
