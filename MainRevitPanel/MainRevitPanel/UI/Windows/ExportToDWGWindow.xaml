<Window x:Class="MainRevitPanel.UI.Windows.ExportToDWGWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:local="clr-namespace:MainRevitPanel.UI.Windows"
            xmlns:vm="clr-namespace:MainRevitPanel.UI.ViewModel"
            mc:Ignorable="d" 
            Title="Экспорт листов в DWG"
            Height="700" Width="900"
            WindowStartupLocation="CenterScreen"
            Background="#F0F0F0"
            WindowStyle="SingleBorderWindow"
            ResizeMode="CanResizeWithGrip">
   
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Первый ComboBox (Фильтры) -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
            <TextBlock Text="Фильтры:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding ListFilters}"
                      SelectedItem="{Binding SelectedFilter}"
                      DisplayMemberPath="Name"
                      Height="30"/>
        </StackPanel>

        <!-- Второй ComboBox (Листы) -->
        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
            <TextBlock Text="Параметры:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding ListParameters}"
                      SelectedItem="{Binding SelectedParameter}"
                      DisplayMemberPath="Title"
                      Height="30"/>
        </StackPanel>

        <!-- ListBox (Отображение листов) -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,10">
            <TextBlock Text="Отфильтрованный список листов:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ListBox ItemsSource="{Binding SheetsView}"
                     SelectedItem="{Binding SelectedSheet}"
                     Height="250">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Text="-" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Content}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Информация о выбранном элементе -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" 
                BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="10"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Выбранный элемент:" FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedSheet.Title, StringFormat='Заголовок: {0}'}" 
                           Margin="10,5,0,0"/>
                <TextBlock Text="{Binding SelectedSheet.Content, StringFormat='Содержание: {0}'}" 
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
