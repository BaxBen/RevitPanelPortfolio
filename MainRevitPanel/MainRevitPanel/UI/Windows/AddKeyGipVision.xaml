<Window x:Class="MainRevitPanel.UI.Windows.AddKeyGipVisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:MainRevitPanel.UI.Windows"
        mc:Ignorable="d" 
        Title="GIP VISION" Height="280" Width="400"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="⚠️" FontSize="32" Foreground="#FFA500" Margin="0,0,10,0"/>
            <TextBlock FontSize="20" FontWeight="Bold" VerticalAlignment="Center">
                <Run Text="Ключ отсутствует,"/>
                <LineBreak/>
                <Run Text="{Binding TextInfo}"/>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Введите ключ:" FontSize="14" Margin="0,0,0,5"/>

        <TextBox Grid.Row="2" 
                 Text="{Binding SelectedText}"
                 FontSize="16" 
                 VerticalAlignment="Top"
                 Height="40"
                 BorderBrush="#0078D4"
                 BorderThickness="2"
                 ToolTip="Вставьте или введите ключ активации"/>

        <Button Grid.Row="3" 
                Content="Проверить ключ" 
                Width="120" 
                Height="35" 
                Margin="0,20,0,0"
                HorizontalAlignment="Right"
                Command="{Binding CheckKeyCommand}"/>
    </Grid>
</Window>
