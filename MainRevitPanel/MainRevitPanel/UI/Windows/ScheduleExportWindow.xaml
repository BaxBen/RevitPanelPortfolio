<Window x:Class="MainRevitPanel.UI.Windows.ExportSchedulesToExcelWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:local="clr-namespace:MainRevitPanel.UI.Windows"
            mc:Ignorable="d" 
            Title="Экспорт спецификаций" 
            Height="400" Width="500"
            WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите спецификации для экспорта:" 
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="SchedulesListBox" 
                 SelectionMode="Multiple"
                 DisplayMemberPath="Name"
                 Margin="0,0,0,10"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Выбрать все" 
                    Click="SelectAll_Click" 
                    Width="100" Margin="0,0,10,0"/>
            <Button Content="Экспортировать" 
                    Click="Export_Click" 
                    Width="100" Margin="0,0,10,0"
                    IsDefault="True"/>
            <Button Content="Отмена" 
                    Click="Cancel_Click" 
                    Width="100"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
