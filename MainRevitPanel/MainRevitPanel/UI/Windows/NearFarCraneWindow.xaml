<Window x:Class="MainRevitPanel.UI.Windows.NearFarCraneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="Поиск крана"
        Height="450" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
               FontSize="14" 
               FontWeight="Bold" 
               Margin="0,0,0,10"/>

        <DataGrid ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem}"
            Grid.Row="1" 
            AutoGenerateColumns="False" 
            IsReadOnly="True"
            SelectionMode="Single"
            Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Кран" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="Путь" Binding="{Binding StringPipe}" Width="400"/>
                <DataGridTextColumn Header="Длина (мм²)" Binding="{Binding Length, StringFormat={}{0:F2}}" Width="76"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" 
                Orientation="Horizontal" 
                HorizontalAlignment="Center"
                Margin="0,0,0,10">

            <Button Content="Подсветить выбранное" 
                Width="150" 
                Margin="5"
                Command="{Binding HighlightCommand}"/>

            <Button Content="Закрыть" 
                Width="100" 
                Margin="5"
                Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>